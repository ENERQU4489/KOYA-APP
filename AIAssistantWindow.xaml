<Window x:Class="KOYA_APP.AIAssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KOYA AI" Height="130" Width="460"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" 
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False" Topmost="True"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#15FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Storyboard x:Key="GlowAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="MainShadow" Storyboard.TargetProperty="BlurRadius" From="15" To="35" Duration="0:0:2"/>
            <DoubleAnimation Storyboard.TargetName="MainShadow" Storyboard.TargetProperty="Opacity" From="0.3" To="0.6" Duration="0:0:2"/>
        </Storyboard>

        <Storyboard x:Key="ThinkingAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="Wave1" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.8" To="1.4" Duration="0:0:1.5"/>
            <DoubleAnimation Storyboard.TargetName="Wave1" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.8" To="1.4" Duration="0:0:1.5"/>
            <DoubleAnimation Storyboard.TargetName="Wave1" Storyboard.TargetProperty="Opacity" From="0.5" To="0" Duration="0:0:1.5"/>
            <DoubleAnimation Storyboard.TargetName="Wave2" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.8" To="1.4" Duration="0:0:1.5" BeginTime="0:0:0.75"/>
            <DoubleAnimation Storyboard.TargetName="Wave2" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.8" To="1.4" Duration="0:0:1.5" BeginTime="0:0:0.75"/>
            <DoubleAnimation Storyboard.TargetName="Wave2" Storyboard.TargetProperty="Opacity" From="0.5" To="0" Duration="0:0:1.5" BeginTime="0:0:0.75"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded"><BeginStoryboard Storyboard="{StaticResource GlowAnimation}"/></EventTrigger>
    </Window.Triggers>

    <Grid x:Name="OuterContainer" Margin="30">
        <Border x:Name="MainBorder" CornerRadius="20" BorderThickness="1" BorderBrush="#55FFFFFF">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FC0D0D0D" Offset="0"/>
                    <GradientStop Color="#FF181818" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect x:Name="MainShadow" BlurRadius="20" ShadowDepth="0" Color="White" Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <!-- Waves -->
                <Grid x:Name="ThinkingOverlay" Visibility="Collapsed" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse x:Name="Wave1" Width="80" Height="80" Stroke="White" StrokeThickness="1" Opacity="0">
                        <Ellipse.RenderTransform><ScaleTransform CenterX="40" CenterY="40"/></Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="Wave2" Width="80" Height="80" Stroke="White" StrokeThickness="1" Opacity="0">
                        <Ellipse.RenderTransform><ScaleTransform CenterX="40" CenterY="40"/></Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>

                <Grid x:Name="ContentGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header/Input -->
                    <Grid Grid.Row="0" Margin="15,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="AI" Foreground="White" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="5,0,15,0">
                            <TextBlock.Effect><DropShadowEffect BlurRadius="8" Color="White" Opacity="0.3"/></TextBlock.Effect>
                        </TextBlock>

                        <TextBox x:Name="PromptInput" Grid.Column="1" Background="Transparent" Foreground="White" 
                                 BorderThickness="0" VerticalContentAlignment="Center" FontSize="15" 
                                 CaretBrush="White" KeyDown="PromptInput_KeyDown" SelectionBrush="#44FFFFFF"/>
                        
                        <TextBlock IsHitTestVisible="False" Text="Zadaj pytanie..." VerticalAlignment="Center" 
                                   HorizontalAlignment="Left" Grid.Column="1" Margin="2,0" Foreground="#88FFFFFF" FontSize="15">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=PromptInput}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ComboBox x:Name="ProviderSelector" Grid.Column="2" Width="90" Height="30" Margin="5,0" 
                                  Background="#33FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="White"
                                  VerticalContentAlignment="Center" SelectionChanged="ProviderSelector_SelectionChanged">
                            <ComboBoxItem Content="Google" IsSelected="True"/>
                            <ComboBoxItem Content="Groq"/>
                            <ComboBoxItem Content="OpenAI"/>
                        </ComboBox>

                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <Button Content="&#xE722;" FontFamily="{StaticResource IconFont}" Style="{StaticResource IconButton}" Width="40" Height="40" Click="Capture_Click" Foreground="White"/>
                            <StackPanel x:Name="ExpandedToolbar" Orientation="Horizontal" Visibility="Collapsed">
                                <Button Content="&#xE16C;" FontFamily="{StaticResource IconFont}" Style="{StaticResource IconButton}" Width="40" Height="40" Click="AttachFile_Click" Margin="5,0" Foreground="White"/>
                                <Button Content="&#xE115;" FontFamily="{StaticResource IconFont}" Style="{StaticResource IconButton}" Width="40" Height="40" Click="Settings_Click" Margin="5,0" Foreground="White"/>
                            </StackPanel>
                            <Button Content="&#xE106;" FontFamily="{StaticResource IconFont}" Style="{StaticResource IconButton}" Width="40" Height="40" Click="Close_Click" Foreground="White"/>
                        </StackPanel>
                    </Grid>

                    <!-- Main Content Area -->
                    <Grid x:Name="ExpandedView" Grid.Row="1" Visibility="Collapsed" Margin="20,5,20,20">
                        <!-- Setup Overlay -->
                        <Border x:Name="SetupView" Visibility="Collapsed" Background="#F00D0D0D" CornerRadius="12" BorderThickness="2" BorderBrush="White" Panel.ZIndex="10" Padding="25">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="KONFIGURACJA AI" Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                    
                                    <TextBlock Text="Klucz Google Gemini (aistudio.google.com):" Foreground="White" FontSize="11" Margin="0,5" FontWeight="Bold"/>
                                    <Border Background="#33FFFFFF" CornerRadius="8" BorderThickness="1" BorderBrush="White" Padding="12,8" Margin="0,0,0,10">
                                        <TextBox x:Name="ApiKeyInput" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" CaretBrush="White"/>
                                    </Border>

                                    <TextBlock Text="Klucz Groq (console.groq.com):" Foreground="White" FontSize="11" Margin="0,5" FontWeight="Bold"/>
                                    <Border Background="#33FFFFFF" CornerRadius="8" BorderThickness="1" BorderBrush="White" Padding="12,8" Margin="0,0,0,10">
                                        <TextBox x:Name="GroqKeyInput" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" CaretBrush="White"/>
                                    </Border>

                                    <TextBlock Text="Klucz OpenAI (platform.openai.com):" Foreground="White" FontSize="11" Margin="0,5" FontWeight="Bold"/>
                                    <Border Background="#33FFFFFF" CornerRadius="8" BorderThickness="1" BorderBrush="White" Padding="12,8" Margin="0,0,0,20">
                                        <TextBox x:Name="OpenAIKeyInput" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" CaretBrush="White"/>
                                    </Border>

                                    <Button Style="{StaticResource IconButton}" Background="#44FFFFFF" Height="45" Click="SaveKey_Click">
                                        <TextBlock Text="ZAPISZ USTAWIENIA AI" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                    </Button>
                                    
                                    <Button Style="{StaticResource IconButton}" Height="30" Margin="0,10,0,0" Click="ResetKey_Click">
                                        <TextBlock Text="WYCZYŚĆ WSZYSTKIE KLUCZE" Foreground="White" FontSize="11" Opacity="0.7"/>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Normal View (Response & Files) -->
                        <Grid x:Name="NormalView">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <ItemsControl x:Name="AttachedFilesList" Margin="0,0,0,10">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#33FFFFFF" CornerRadius="12" Padding="10,4" Margin="0,0,5,5" BorderBrush="White" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE160;" FontFamily="{StaticResource IconFont}" FontSize="10" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Grid.Row="1" Background="#15FFFFFF" CornerRadius="15" BorderThickness="1.5" BorderBrush="#44FFFFFF">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
                                    <TextBlock x:Name="ResponseText" Text="Czekam na Twój prompt..." Foreground="White" FontSize="14" TextWrapping="Wrap" LineHeight="22" FontWeight="SemiBold"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
