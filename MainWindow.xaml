<Window x:Class="KOYA_APP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KOYA" Height="600" Width="1100"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" 
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True" Topmost="True"
        Icon="Assets/logo.png">
    
    <Border x:Name="WindowBorder" CornerRadius="0" BorderThickness="1.5">
        <Border.Background>
            <!-- Achromatic Cyber Gradient Background -->
            <RadialGradientBrush Center="0.8,0.2" GradientOrigin="0.8,0.2" RadiusX="1.2" RadiusY="1.2">
                <GradientStop Color="#111111" Offset="0"/>
                <GradientStop Color="#050505" Offset="0.6"/>
                <GradientStop Color="Black" Offset="1"/>
            </RadialGradientBrush>
        </Border.Background>
        
        <Border.BorderBrush>
            <SolidColorBrush x:Name="BorderGlowBrush" Color="#33FFFFFF"/>
        </Border.BorderBrush>

        <Border.Effect>
            <DropShadowEffect x:Name="WindowGlow" BlurRadius="20" ShadowDepth="0" Color="White" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <!-- Main Content (Hidden initially) -->
            <Grid x:Name="MainContent" Opacity="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Grid Grid.Row="0" MouseDown="TitleBar_MouseDown" Background="#0AFFFFFF">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Image Source="Assets/logo.png" Height="30" Grid.ColumnSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="White" Opacity="0.5"/>
                        </Image.Effect>
                    </Image>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0">
                        <Button Content="&#xE949;" Style="{StaticResource GlassButtonStyle}" Click="Minimize_Click" BorderThickness="0" Width="40" Height="40" FontSize="12"/>
                        <Button Content="&#xE106;" Style="{StaticResource GlassButtonStyle}" Click="Close_Click" BorderThickness="0" Width="40" Height="40" FontSize="12"/>
                    </StackPanel>
                </Grid>

                <!-- Main Workspace -->
                <Grid Grid.Row="1" Margin="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: 4x3 Grid -->
                    <UniformGrid Grid.Column="0" Rows="3" Columns="4">
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="0" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="1" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="2" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="3" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="4" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="5" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="6" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="7" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="8" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="9" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="10" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                        <Button Style="{StaticResource GlassButtonStyle}" Tag="11" Click="OnDeckButtonClick" Content="&#xE710;" Margin="8"/>
                    </UniformGrid>

                    <!-- Right: Knobs -->
                    <Grid Grid.Column="1" Margin="20,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>
                        
                        <Viewbox Grid.Row="0" Margin="10">
                            <Button Style="{StaticResource KnobButtonStyle}" Tag="12" Click="OnDeckButtonClick" 
                                    Content="&#xE995;" FontFamily="{StaticResource IconFont}" Width="100" Height="100" MouseWheel="OnKnobMouseWheel"/>
                        </Viewbox>

                        <Viewbox Grid.Row="2" Margin="10">
                            <Button Style="{StaticResource KnobButtonStyle}" Tag="13" Click="OnDeckButtonClick" 
                                    Content="&#xE995;" FontFamily="{StaticResource IconFont}" Width="100" Height="100" MouseWheel="OnKnobMouseWheel"/>
                        </Viewbox>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Startup Intro Overlay -->
            <Grid x:Name="IntroOverlay" Background="Black">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="LetterK" Text="K" Opacity="0" Foreground="White" FontSize="86" FontFamily="{StaticResource MainFont}" Margin="12">
                        <TextBlock.Effect><DropShadowEffect BlurRadius="20" Color="White" Opacity="0.8"/></TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="LetterO" Text="O" Opacity="0" Foreground="White" FontSize="86" FontFamily="{StaticResource MainFont}" Margin="12">
                        <TextBlock.Effect><DropShadowEffect BlurRadius="20" Color="White" Opacity="0.8"/></TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="LetterY" Text="Y" Opacity="0" Foreground="White" FontSize="86" FontFamily="{StaticResource MainFont}" Margin="12">
                        <TextBlock.Effect><DropShadowEffect BlurRadius="20" Color="#AAAAAA" Opacity="0.8"/></TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="LetterA" Text="A" Opacity="0" Foreground="White" FontSize="86" FontFamily="{StaticResource MainFont}" Margin="12">
                        <TextBlock.Effect><DropShadowEffect BlurRadius="20" Color="#AAAAAA" Opacity="0.8"/></TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
                
                <!-- Digital Scan Line -->
                <Rectangle x:Name="ScanLine" Height="2" Fill="White" VerticalAlignment="Top" Opacity="0">
                    <Rectangle.Effect><BlurEffect x:Name="scanBlur" Radius="10"/></Rectangle.Effect>
                </Rectangle>

                <Border x:Name="FlashOverlay" Background="White" Opacity="0"/>
            </Grid>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Window Breathing Glow -->
                    <ColorAnimation Storyboard.TargetName="BorderGlowBrush" Storyboard.TargetProperty="Color" From="#33FFFFFF" To="White" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="WindowGlow" Storyboard.TargetProperty="Opacity" From="0.2" To="0.4" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever"/>

                    <!-- Digital Scan Animation -->
                    <DoubleAnimation Storyboard.TargetName="ScanLine" Storyboard.TargetProperty="Opacity" From="0" To="0.8" Duration="0:0:0.2" BeginTime="0:0:0.3"/>
                    <ThicknessAnimation Storyboard.TargetName="ScanLine" Storyboard.TargetProperty="Margin" From="0,0,0,0" To="0,600,0,0" Duration="0:0:2.5" BeginTime="0:0:0.3"/>
                    <DoubleAnimation Storyboard.TargetName="ScanLine" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" BeginTime="0:0:2.8"/>

                    <!-- Letter Sequence with QuinticEase -->
                    <DoubleAnimation Storyboard.TargetName="LetterK" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5" BeginTime="0:0:0.6">
                        <DoubleAnimation.EasingFunction><QuinticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LetterO" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5" BeginTime="0:0:1.0">
                        <DoubleAnimation.EasingFunction><QuinticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LetterY" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5" BeginTime="0:0:1.4">
                        <DoubleAnimation.EasingFunction><QuinticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LetterA" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5" BeginTime="0:0:1.8">
                        <DoubleAnimation.EasingFunction><QuinticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    
                    <!-- Flash & Transition -->
                    <DoubleAnimation Storyboard.TargetName="FlashOverlay" Storyboard.TargetProperty="Opacity" From="0" To="0.8" Duration="0:0:0.1" BeginTime="0:0:2.8"/>
                    <DoubleAnimation Storyboard.TargetName="FlashOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.6" BeginTime="0:0:2.9"/>
                    
                    <DoubleAnimation Storyboard.TargetName="IntroOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.8" BeginTime="0:0:2.9"/>
                    <BooleanAnimationUsingKeyFrames Storyboard.TargetName="IntroOverlay" Storyboard.TargetProperty="IsHitTestVisible" BeginTime="0:0:3.7">
                        <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
                    </BooleanAnimationUsingKeyFrames>
                    
                    <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:1.2" BeginTime="0:0:3.1">
                        <DoubleAnimation.EasingFunction><QuinticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
