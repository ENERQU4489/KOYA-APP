<Window x:Class="StreamDeckApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stream Deck" Height="550" Width="950"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="DeckButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="#333" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#121212" CornerRadius="15" BorderBrush="#222" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0">
                    <Button Content="—" Click="Minimize_Click" Background="Transparent" Foreground="White" BorderThickness="0" Width="40"/>
                    <Button Content="✕" Click="Close_Click" Background="Transparent" Foreground="Red" BorderThickness="0" Width="40"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <UniformGrid Columns="4" Rows="3" Margin="20">
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="0" Click="OnDeckButtonClick"/>
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="1" Click="OnDeckButtonClick"/>
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="2" Click="OnDeckButtonClick"/>
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="3" Click="OnDeckButtonClick"/>
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="4" Click="OnDeckButtonClick"/>
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="5" Click="OnDeckButtonClick"/>
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="6" Click="OnDeckButtonClick"/>
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="7" Click="OnDeckButtonClick"/>
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="8" Click="OnDeckButtonClick"/>
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="9" Click="OnDeckButtonClick"/>
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="10" Click="OnDeckButtonClick"/>
                    <Button Style="{StaticResource DeckButtonStyle}" Content="Pusty" Tag="11" Click="OnDeckButtonClick"/>
                </UniformGrid>
                <Border Grid.Column="1" Background="#181818" CornerRadius="0,0,15,0">
                    <Button Width="80" Height="80" Content="VOL+" Click="VolumeUp_Click" MouseRightButtonDown="VolumeDown_Click" Background="#252525" Foreground="White"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>