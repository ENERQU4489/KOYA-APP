<Window x:Class="KOYA_APP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KOYA_APP"
        Title="KOYA" Height="650" Width="1100"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" 
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True" Topmost="True"
        Icon="Assets/logo.png"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Style TargetType="{x:Type local:MainWindow}">
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <WindowChrome CaptionHeight="60" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="8" UseAeroCaptionButtons="False"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border x:Name="WindowBorder" CornerRadius="12" BorderThickness="1.5" 
            TextElement.FontFamily="{StaticResource MainFont}" TextElement.Foreground="White">
        <Border.Background>
            <SolidColorBrush Color="#050505"/>
        </Border.Background>
        
        <Border.BorderBrush>
            <SolidColorBrush x:Name="BorderGlowBrush" Color="#33FFFFFF"/>
        </Border.BorderBrush>

        <Border.Effect>
            <DropShadowEffect x:Name="WindowGlow" BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.5"/>
        </Border.Effect>

        <Grid x:Name="RootGrid">
            <!-- High-End Atmospheric Background Layer -->
            <Canvas x:Name="BackgroundCanvas" IsHitTestVisible="False" Opacity="0.4">
                <!-- Nebula 1: Top-Left dominant, moves towards center-top -->
                <Border x:Name="Blob1" Width="800" Height="800" CornerRadius="400">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                            <GradientStop Color="#0FFFFFFF" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="0.8"/>
                        </RadialGradientBrush>
                    </Border.Background>
                    <Border.RenderTransform>
                        <TranslateTransform X="-400" Y="-300"/>
                    </Border.RenderTransform>
                </Border>

                <!-- Nebula 2: Bottom-Right dominant, moves towards center-bottom -->
                <Border x:Name="Blob2" Width="1000" Height="1000" CornerRadius="500">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                            <GradientStop Color="#08FFFFFF" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="0.8"/>
                        </RadialGradientBrush>
                    </Border.Background>
                    <Border.RenderTransform>
                        <TranslateTransform X="900" Y="400"/>
                    </Border.RenderTransform>
                </Border>
                
                <Canvas.Triggers>
                    <EventTrigger RoutedEvent="Canvas.Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetName="Blob1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="600" Duration="0:0:50"/>
                                <DoubleAnimation Storyboard.TargetName="Blob1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="100" Duration="0:0:40"/>
                                <DoubleAnimation Storyboard.TargetName="Blob2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="-200" Duration="0:1:0"/>
                                <DoubleAnimation Storyboard.TargetName="Blob2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="100" Duration="0:0:50"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Canvas.Triggers>
            </Canvas>

            <!-- Main UI -->
            <Grid x:Name="MainContent" Opacity="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <!-- 1. Top Bar -->
                <Grid Grid.Row="0" Background="#0AFFFFFF">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="25,0" VerticalAlignment="Center">
                        <TextBlock Text="KOYA" Foreground="White" FontSize="24" FontWeight="ExtraBold">
                            <TextBlock.Effect><DropShadowEffect BlurRadius="12" Color="White" Opacity="0.3"/></TextBlock.Effect>
                        </TextBlock>
                        
                        <Border Background="#15FFFFFF" CornerRadius="4" Padding="8,2" Margin="20,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#44FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="StatusText" Text="INITIALIZING" Foreground="#88FFFFFF" FontSize="9" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Control Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="PopupToggleButton" Content="&#xEA8F;" Style="{StaticResource GlassButtonStyle}" Click="PopupToggle_Click" BorderThickness="0" Width="45" Height="45" FontSize="14" ToolTip="Powiadomienia"/>
                        <Button Content="&#xE897;" Style="{StaticResource GlassButtonStyle}" Click="Tutorial_Click" BorderThickness="0" Width="45" Height="45" FontSize="14" ToolTip="Samouczek"/>
                        <Button Content="&#xE921;" Style="{StaticResource GlassButtonStyle}" Click="Minimize_Click" BorderThickness="0" Width="45" Height="45" FontSize="12"/>
                        <Button Content="&#xE106;" Style="{StaticResource GlassButtonStyle}" Click="Close_Click" BorderThickness="0" Width="45" Height="45" FontSize="12" Foreground="#FF5555"/>
                    </StackPanel>
                </Grid>

                <!-- 2. Grid & Sidebar -->
                <Grid Grid.Row="1" Margin="40,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <!-- Buttons with Fixed Proportions -->
                    <UniformGrid Grid.Column="0" Rows="3" Columns="4" Margin="0,0,30,0" VerticalAlignment="Center">
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="0" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="1" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="2" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="3" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="4" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="5" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="6" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="7" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="8" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="9" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="10" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                        <Viewbox Margin="8"><Button Style="{StaticResource GlassButtonStyle}" Tag="11" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Width="100" Height="100"/></Viewbox>
                    </UniformGrid>

                    <!-- Knob Sidebar -->
                    <Border Grid.Column="1" Background="#0AFFFFFF" CornerRadius="20" BorderThickness="1" BorderBrush="#15FFFFFF" Padding="25">
                        <StackPanel VerticalAlignment="Center">
                            <Button Style="{StaticResource KnobButtonStyle}" Tag="12" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" 
                                    Content="&#xE995;" Width="120" Height="120" MouseWheel="OnKnobMouseWheel" Margin="0,0,0,40"/>
                            <Button Style="{StaticResource KnobButtonStyle}" Tag="13" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" 
                                    Content="&#xE995;" Width="120" Height="120" MouseWheel="OnKnobMouseWheel"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 3. Footer -->
                <Grid Grid.Row="2" Background="#05FFFFFF">
                    <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="20" Height="20" Cursor="SizeNWSE" Background="Transparent" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Data="M4,16 L16,16 L16,4" Stroke="#44FFFFFF" StrokeThickness="1.5" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Disconnection Overlay -->
            <Grid x:Name="DisconnectedOverlay" Background="#F0000000" Visibility="Visible" MouseLeftButtonUp="DisconnectedOverlay_Click">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource IconFont}" FontSize="80" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,30">
                        <TextBlock.Effect><DropShadowEffect BlurRadius="30" Color="White" Opacity="0.4"/></TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="CONNECTION REQUIRED" Foreground="White" FontSize="32" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="PLEASE PLUG IN YOUR KOYA HARDWARE" Foreground="#66FFFFFF" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    
                    <Border BorderBrush="White" BorderThickness="2" CornerRadius="8" Padding="30,15" Margin="0,60,0,0" HorizontalAlignment="Center" Cursor="Hand">
                        <TextBlock Text="LAUNCH OFFLINE MODE" Foreground="White" FontSize="12" FontWeight="ExtraBold"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Intro Overlay -->
            <Grid x:Name="IntroOverlay" Background="Black">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid Margin="15"><TextBlock x:Name="LetterK" Text="K" Opacity="0" Foreground="White" FontSize="96" FontWeight="Bold" FontFamily="{StaticResource MainFont}" RenderTransformOrigin="0.5,0.5"><TextBlock.RenderTransform><ScaleTransform x:Name="ScaleK" ScaleX="3" ScaleY="3"/></TextBlock.RenderTransform><TextBlock.Effect><BlurEffect x:Name="BlurK" Radius="40"/></TextBlock.Effect></TextBlock></Grid>
                    <Grid Margin="15"><TextBlock x:Name="LetterO" Text="O" Opacity="0" Foreground="White" FontSize="96" FontWeight="Bold" FontFamily="{StaticResource MainFont}" RenderTransformOrigin="0.5,0.5"><TextBlock.RenderTransform><ScaleTransform x:Name="ScaleO" ScaleX="3" ScaleY="3"/></TextBlock.RenderTransform><TextBlock.Effect><BlurEffect x:Name="BlurO" Radius="40"/></TextBlock.Effect></TextBlock></Grid>
                    <Grid Margin="15"><TextBlock x:Name="LetterY" Text="Y" Opacity="0" Foreground="White" FontSize="96" FontWeight="Bold" FontFamily="{StaticResource MainFont}" RenderTransformOrigin="0.5,0.5"><TextBlock.RenderTransform><ScaleTransform x:Name="ScaleY" ScaleX="3" ScaleY="3"/></TextBlock.RenderTransform><TextBlock.Effect><BlurEffect x:Name="BlurY" Radius="40"/></TextBlock.Effect></TextBlock></Grid>
                    <Grid Margin="15"><TextBlock x:Name="LetterA" Text="A" Opacity="0" Foreground="White" FontSize="96" FontWeight="Bold" FontFamily="{StaticResource MainFont}" RenderTransformOrigin="0.5,0.5"><TextBlock.RenderTransform><ScaleTransform x:Name="ScaleA" ScaleX="3" ScaleY="3"/></TextBlock.RenderTransform><TextBlock.Effect><BlurEffect x:Name="BlurA" Radius="40"/></TextBlock.Effect></TextBlock></Grid>
                </StackPanel>
                <Border x:Name="FlashOverlay" Background="White" Opacity="0"/>
            </Grid>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetName="BorderGlowBrush" Storyboard.TargetProperty="Color" From="#33FFFFFF" To="White" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="WindowGlow" Storyboard.TargetProperty="Opacity" From="0.2" To="0.5" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever"/>

                    <!-- Intro sequence -->
                    <DoubleAnimation Storyboard.TargetName="LetterK" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" BeginTime="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="ScaleK" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.4" BeginTime="0:0:0.5"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ScaleK" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.4" BeginTime="0:0:0.5"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BlurK" Storyboard.TargetProperty="Radius" To="0" Duration="0:0:0.4" BeginTime="0:0:0.5"/>

                    <DoubleAnimation Storyboard.TargetName="LetterO" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" BeginTime="0:0:0.7"/>
                    <DoubleAnimation Storyboard.TargetName="ScaleO" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.4" BeginTime="0:0:0.7"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ScaleO" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.4" BeginTime="0:0:0.7"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BlurO" Storyboard.TargetProperty="Radius" To="0" Duration="0:0:0.4" BeginTime="0:0:0.7"/>

                    <DoubleAnimation Storyboard.TargetName="LetterY" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" BeginTime="0:0:0.9"/>
                    <DoubleAnimation Storyboard.TargetName="ScaleY" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.4" BeginTime="0:0:0.9"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ScaleY" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.4" BeginTime="0:0:0.9"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BlurY" Storyboard.TargetProperty="Radius" To="0" Duration="0:0:0.4" BeginTime="0:0:0.9"/>

                    <DoubleAnimation Storyboard.TargetName="LetterA" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" BeginTime="0:0:1.1"/>
                    <DoubleAnimation Storyboard.TargetName="ScaleA" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.4" BeginTime="0:0:1.1"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ScaleA" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.4" BeginTime="0:0:1.1"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BlurA" Storyboard.TargetProperty="Radius" To="0" Duration="0:0:0.4" BeginTime="0:0:1.1"/>

                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IntroOverlay" Storyboard.TargetProperty="Opacity" BeginTime="0:0:2.0">
                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/><DiscreteDoubleKeyFrame KeyTime="0:0:0.05" Value="0.3"/><DiscreteDoubleKeyFrame KeyTime="0:0:0.1" Value="0.8"/><DiscreteDoubleKeyFrame KeyTime="0:0:0.15" Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimation Storyboard.TargetName="FlashOverlay" Storyboard.TargetProperty="Opacity" From="0" To="0.5" Duration="0:0:0.1" BeginTime="0:0:2.0"/>
                    <DoubleAnimation Storyboard.TargetName="FlashOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.4" BeginTime="0:0:2.1"/>
                    <BooleanAnimationUsingKeyFrames Storyboard.TargetName="IntroOverlay" Storyboard.TargetProperty="IsHitTestVisible" BeginTime="0:0:2.1"><DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/></BooleanAnimationUsingKeyFrames>
                    <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:1.0" BeginTime="0:0:2.0"><DoubleAnimation.EasingFunction><QuinticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
