<Window x:Class="KOYA_APP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KOYA" Height="600" Width="1100"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" 
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True" Topmost="True"
        Icon="Assets/logo.png"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    
    <Border x:Name="WindowBorder" CornerRadius="12" BorderThickness="1.5" 
            TextElement.FontFamily="{StaticResource MainFont}" TextElement.Foreground="White">
        <Border.Background>
            <SolidColorBrush Color="#000000"/>
        </Border.Background>
        
        <Border.BorderBrush>
            <SolidColorBrush x:Name="BorderGlowBrush" Color="#33FFFFFF"/>
        </Border.BorderBrush>

        <Border.Effect>
            <DropShadowEffect x:Name="WindowGlow" BlurRadius="20" ShadowDepth="0" Color="White" Opacity="0.2"/>
        </Border.Effect>

        <Grid x:Name="RootGrid">
            <!-- Animated Background Layer -->
            <Canvas x:Name="BackgroundCanvas" IsHitTestVisible="False">
                <Ellipse x:Name="Blob1" Width="400" Height="400" Fill="#15FFFFFF">
                    <Ellipse.Effect>
                        <BlurEffect Radius="150"/>
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <TranslateTransform X="-200" Y="-200"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="Blob2" Width="500" Height="500" Fill="#0AFFFFFF">
                    <Ellipse.Effect>
                        <BlurEffect Radius="200"/>
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <TranslateTransform X="600" Y="300"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                
                <Canvas.Triggers>
                    <EventTrigger RoutedEvent="Canvas.Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetName="Blob1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="800" Duration="0:0:30"/>
                                <DoubleAnimation Storyboard.TargetName="Blob1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="400" Duration="0:0:25"/>
                                <DoubleAnimation Storyboard.TargetName="Blob2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="-300" Duration="0:0:40"/>
                                <DoubleAnimation Storyboard.TargetName="Blob2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="-100" Duration="0:0:35"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Canvas.Triggers>
            </Canvas>

            <!-- Main Content Container with Rounding -->
            <Border x:Name="MainContentBorder" CornerRadius="12" ClipToBounds="True">
                <Grid x:Name="MainContent" Opacity="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Title Bar -->
                    <Grid Grid.Row="0" MouseDown="TitleBar_MouseDown" Background="#0AFFFFFF">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                            <TextBlock Text="KOYA" Foreground="White" FontSize="28" FontWeight="Bold" FontFamily="{StaticResource MainFont}">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="10" Color="White" ShadowDepth="0" Opacity="0.3"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            
                            <!-- HID Connection Status Indicator -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="30,5,0,0">
                                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#44FFFFFF" Margin="0,2,8,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="White" Opacity="0.6"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="StatusText" Text="DISCONNECTED" Foreground="#66FFFFFF" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0">
                            <Button x:Name="PopupToggleButton" Content="&#xEA8F;" Style="{StaticResource GlassButtonStyle}" Click="PopupToggle_Click" BorderThickness="0" Width="40" Height="40" FontSize="14" ToolTip="Toggle Popup Notifications"/>
                            <Button Content="&#xE897;" Style="{StaticResource GlassButtonStyle}" Click="Tutorial_Click" BorderThickness="0" Width="40" Height="40" FontSize="14" ToolTip="Tutorial"/>
                            <Button Content="&#xE949;" Style="{StaticResource GlassButtonStyle}" Click="Minimize_Click" BorderThickness="0" Width="40" Height="40" FontSize="12"/>
                            <Button Content="&#xE106;" Style="{StaticResource GlassButtonStyle}" Click="Close_Click" BorderThickness="0" Width="40" Height="40" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Buttons Grid -->
                        <UniformGrid Grid.Column="0" Rows="3" Columns="4">
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="0" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="1" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="2" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="3" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="4" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="5" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="6" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="7" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="8" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="9" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="10" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                            <Button Style="{StaticResource GlassButtonStyle}" Tag="11" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" Content="&#xE710;" Margin="8"/>
                        </UniformGrid>

                        <!-- Knobs Column -->
                        <Grid Grid.Column="1" Margin="-30,0,30,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*"/>
                                <RowDefinition Height="0.5*"/>
                                <RowDefinition Height="1*"/>
                            </Grid.RowDefinitions>
                            
                            <Viewbox Grid.Row="0" Margin="10">
                                <Button Style="{StaticResource KnobButtonStyle}" Tag="12" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" 
                                        Content="&#xE995;" Width="100" Height="100" MouseWheel="OnKnobMouseWheel"/>
                            </Viewbox>
                            
                            <Viewbox Grid.Row="2" Margin="10">
                                <Button Style="{StaticResource KnobButtonStyle}" Tag="13" Click="OnDeckButtonClick" MouseRightButtonUp="OnDeckButtonRightClick" 
                                        Content="&#xE995;" Width="100" Height="100" MouseWheel="OnKnobMouseWheel"/>
                            </Viewbox>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Disconnection Overlay -->
            <Grid x:Name="DisconnectedOverlay" Background="#EE000000" Visibility="Visible" MouseLeftButtonUp="DisconnectedOverlay_Click">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource IconFont}" FontSize="64" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="20" Color="White" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="PLEASE CONNECT" Foreground="White" FontSize="28" FontWeight="Bold" FontFamily="{StaticResource MainFont}" HorizontalAlignment="Center"/>
                    <TextBlock Text="KOYA STREAM DECK" Foreground="#88FFFFFF" FontSize="14" FontFamily="{StaticResource MainFont}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    
                    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="4" Padding="20,10" Margin="0,40,0,0" HorizontalAlignment="Center" Cursor="Hand">
                        <TextBlock Text="CLICK TO EDIT OFFLINE" Foreground="#AAFFFFFF" FontSize="12" FontWeight="Bold" FontFamily="{StaticResource MainFont}"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Startup Intro Overlay -->
            <Grid x:Name="IntroOverlay" Background="Black">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid Margin="12">
                        <TextBlock x:Name="LetterK" Text="K" Opacity="0" Foreground="White" FontSize="86" FontFamily="{StaticResource MainFont}" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform><ScaleTransform x:Name="ScaleK" ScaleX="3" ScaleY="3"/></TextBlock.RenderTransform>
                            <TextBlock.Effect><BlurEffect x:Name="BlurK" Radius="40"/></TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                    <Grid Margin="12">
                        <TextBlock x:Name="LetterO" Text="O" Opacity="0" Foreground="White" FontSize="86" FontFamily="{StaticResource MainFont}" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform><ScaleTransform x:Name="ScaleO" ScaleX="3" ScaleY="3"/></TextBlock.RenderTransform>
                            <TextBlock.Effect><BlurEffect x:Name="BlurO" Radius="40"/></TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                    <Grid Margin="12">
                        <TextBlock x:Name="LetterY" Text="Y" Opacity="0" Foreground="White" FontSize="86" FontFamily="{StaticResource MainFont}" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform><ScaleTransform x:Name="ScaleY" ScaleX="3" ScaleY="3"/></TextBlock.RenderTransform>
                            <TextBlock.Effect><BlurEffect x:Name="BlurY" Radius="40"/></TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                    <Grid Margin="12">
                        <TextBlock x:Name="LetterA" Text="A" Opacity="0" Foreground="White" FontSize="86" FontFamily="{StaticResource MainFont}" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform><ScaleTransform x:Name="ScaleA" ScaleX="3" ScaleY="3"/></TextBlock.RenderTransform>
                            <TextBlock.Effect><BlurEffect x:Name="BlurA" Radius="40"/></TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </StackPanel>
                
                <Border x:Name="FlashOverlay" Background="White" Opacity="0"/>
            </Grid>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetName="BorderGlowBrush" Storyboard.TargetProperty="Color" From="#33FFFFFF" To="White" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="WindowGlow" Storyboard.TargetProperty="Opacity" From="0.2" To="0.4" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever"/>

                    <!-- Sequence K -->
                    <DoubleAnimation Storyboard.TargetName="LetterK" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" BeginTime="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="ScaleK" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.4" BeginTime="0:0:0.5"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ScaleK" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.4" BeginTime="0:0:0.5"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BlurK" Storyboard.TargetProperty="Radius" To="0" Duration="0:0:0.4" BeginTime="0:0:0.5"/>

                    <!-- Sequence O -->
                    <DoubleAnimation Storyboard.TargetName="LetterO" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" BeginTime="0:0:0.7"/>
                    <DoubleAnimation Storyboard.TargetName="ScaleO" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.4" BeginTime="0:0:0.7"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ScaleO" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.4" BeginTime="0:0:0.7"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BlurO" Storyboard.TargetProperty="Radius" To="0" Duration="0:0:0.4" BeginTime="0:0:0.7"/>

                    <!-- Sequence Y -->
                    <DoubleAnimation Storyboard.TargetName="LetterY" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" BeginTime="0:0:0.9"/>
                    <DoubleAnimation Storyboard.TargetName="ScaleY" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.4" BeginTime="0:0:0.9"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ScaleY" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.4" BeginTime="0:0:0.9"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BlurY" Storyboard.TargetProperty="Radius" To="0" Duration="0:0:0.4" BeginTime="0:0:0.9"/>

                    <!-- Sequence A -->
                    <DoubleAnimation Storyboard.TargetName="LetterA" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" BeginTime="0:0:1.1"/>
                    <DoubleAnimation Storyboard.TargetName="ScaleA" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.4" BeginTime="0:0:1.1"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ScaleA" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.4" BeginTime="0:0:1.1"><DoubleAnimation.EasingFunction><PowerEase Power="4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BlurA" Storyboard.TargetProperty="Radius" To="0" Duration="0:0:0.4" BeginTime="0:0:1.1"/>

                    <!-- Final Glitch Flicker -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IntroOverlay" Storyboard.TargetProperty="Opacity" BeginTime="0:0:2.0">
                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.05" Value="0.3"/>
                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.1" Value="0.8"/>
                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.15" Value="0"/>
                    </DoubleAnimationUsingKeyFrames>

                    <DoubleAnimation Storyboard.TargetName="FlashOverlay" Storyboard.TargetProperty="Opacity" From="0" To="0.5" Duration="0:0:0.1" BeginTime="0:0:2.0"/>
                    <DoubleAnimation Storyboard.TargetName="FlashOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.4" BeginTime="0:0:2.1"/>
                    
                    <BooleanAnimationUsingKeyFrames Storyboard.TargetName="IntroOverlay" Storyboard.TargetProperty="IsHitTestVisible" BeginTime="0:0:2.1">
                        <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
                    </BooleanAnimationUsingKeyFrames>
                    
                    <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.8" BeginTime="0:0:2.0">
                        <DoubleAnimation.EasingFunction><QuinticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>