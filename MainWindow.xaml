<Window x:Class="KOYA_APP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stream Deck" Height="550" Width="950"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" WindowStartupLocation="CenterScreen">
    
    <Border Background="#1E1E1E" CornerRadius="20" BorderBrush="#333333" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="#252525" MouseDown="TitleBar_MouseDown">
                <TextBlock Text="KOYA APP v1.0" Foreground="Gray" VerticalAlignment="Center" Margin="20,0" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0">
                    <Button Content="_" Click="Minimize_Click" Background="Transparent" Foreground="White" BorderThickness="0" Width="40"/>
                    <Button Content="X" Click="Close_Click" Background="Transparent" Foreground="Red" BorderThickness="0" Width="40"/>
                </StackPanel>
            </Grid>

            <!-- Buttons Grid -->
            <UniformGrid Grid.Row="1" Rows="3" Columns="5" Margin="20">
                <Button Content="Pusty" Tag="0" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="1" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="2" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="3" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="4" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="5" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="6" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="7" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="8" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="9" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="10" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="11" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="12" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="13" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
                <Button Content="Pusty" Tag="14" Click="OnDeckButtonClick" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10" Foreground="White" Background="#2D2D2D"/>
            </UniformGrid>

            <!-- Bottom Controls -->
            <StackPanel Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Orientation="Horizontal" Margin="20">
                <Button Content="Vol Up" Click="VolumeUp_Click" Margin="5"/>
                <Button Content="Vol Down" Click="VolumeDown_Click" Margin="5"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
