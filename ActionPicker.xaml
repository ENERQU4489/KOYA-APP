<Window x:Class="KOYA_APP.ActionPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wybierz Akcje" Height="680" Width="650"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" 
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="12" BorderThickness="1.5" 
            TextElement.FontFamily="{StaticResource MainFont}" TextElement.Foreground="White">
        <Border.Background>
            <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,0" RadiusX="1" RadiusY="1">
                <GradientStop Color="#222222" Offset="0"/>
                <GradientStop Color="#050505" Offset="0.8"/>
            </RadialGradientBrush>
        </Border.Background>
        
        <Border.BorderBrush>
            <SolidColorBrush Color="#44FFFFFF"/>
        </Border.BorderBrush>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="WYBIERZ AKCJĘ" FontFamily="{StaticResource MainFont}" Foreground="White" 
                           FontSize="24" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" Color="White" ShadowDepth="0" Opacity="0.3"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="DOSTOSUJ SWOJE KOYA CONSOLE" FontFamily="{StaticResource MainFont}" Foreground="#88FFFFFF" 
                           FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Action Grid -->
            <ListBox x:Name="ActionsListBox" Grid.Row="1" Style="{StaticResource ActionListBoxStyle}" 
                     SelectionChanged="ActionsListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Height="160" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="{Binding Icon}" FontFamily="{StaticResource IconFont}" Foreground="White" 
                                           FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                
                                <TextBlock Grid.Row="1" Text="{Binding Name}" FontFamily="{StaticResource MainFont}" Foreground="White" 
                                           FontSize="13" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxHeight="45" Margin="0,8,0,0"/>
                                
                                <TextBlock Grid.Row="2" Text="{Binding Description}" Foreground="#AABBBBBB" FontSize="10" 
                                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0" MaxHeight="40"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Settings Panel -->
            <StackPanel x:Name="ExtraSettingsPanel" Grid.Row="2" Visibility="Collapsed" Margin="0,15,0,0">
                <TextBlock x:Name="ExtraSettingsTitle" Text="KONFIGURACJA" FontFamily="{StaticResource MainFont}" 
                           Foreground="White" FontSize="10" Margin="0,0,0,8" Opacity="0.8"/>
                <Border BorderBrush="#44FFFFFF" BorderThickness="1" Background="#0AFFFFFF" CornerRadius="8">
                    <Grid>
                        <ComboBox x:Name="DevicesComboBox" Visibility="Collapsed" Height="45" Background="#111111" Foreground="White" BorderThickness="0" Padding="10,0"/>
                        <TextBox x:Name="ShortcutTextBox" Visibility="Collapsed" Height="45" Background="Transparent" Foreground="White" 
                                 TextAlignment="Center" VerticalContentAlignment="Center" IsReadOnly="True" BorderThickness="0"
                                 PreviewKeyDown="ShortcutTextBox_PreviewKeyDown" FontFamily="{StaticResource MainFont}" FontSize="14"/>
                        <TextBox x:Name="PasteTextInput" Visibility="Collapsed" Height="45" Background="Transparent" Foreground="White" 
                                 TextAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0"
                                 FontFamily="{StaticResource MainFont}" FontSize="14" Tag="WPISZ TEKST DO WKLEJENIA..."/>
                        
                        <Grid x:Name="MacroPanel" Visibility="Collapsed" Height="45">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="MacroStatusText" Text="GOTOWY DO NAGRYWANIA" VerticalAlignment="Center" Margin="15,0" FontSize="12" Opacity="0.8"/>
                            <Button x:Name="RecordMacroButton" Grid.Column="1" Click="RecordMacro_Click" Style="{StaticResource GlassButtonStyle}" Width="150" Height="35" Margin="5">
                                <TextBlock x:Name="RecordMacroButtonText" Text="NAGRAJ" FontFamily="{StaticResource MainFont}" FontSize="12"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>

            <UniformGrid Grid.Row="3" Columns="2" Margin="0,20,0,0">
                <Button Click="Cancel_Click" Style="{StaticResource GlassButtonStyle}" 
                        Height="55" Margin="5">
                    <TextBlock Text="ANULUJ" FontFamily="{StaticResource MainFont}" FontSize="14" Foreground="White"/>
                </Button>
                <Button Click="Select_Click" Style="{StaticResource GlassButtonStyle}" 
                        Height="55" Margin="5" Background="#22FFFFFF" BorderBrush="White">
                    <TextBlock Text="ZASTOSUJ" FontFamily="{StaticResource MainFont}" FontSize="14" Foreground="White"/>
                </Button>
            </UniformGrid>
        </Grid>
    </Border>
</Window>