<Window x:Class="KOYA_APP.ActionPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wybor Akcji" Height="450" Width="400"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" 
        WindowStartupLocation="CenterOwner">

    <Border Background="#1E1E1E" BorderBrush="#0078D4" BorderThickness="2" CornerRadius="15">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="WYBIERZ AKCJE" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <ListBox x:Name="ActionsListBox" Grid.Row="1" Background="#252525" Foreground="White" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#0078D4"/>       
                            <TextBlock Text="{Binding Description}" FontSize="10" Opacity="0.6" Foreground="White"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <UniformGrid Grid.Row="2" Columns="2" Margin="0,15,0,0">
                <Button Content="Anuluj" Click="Cancel_Click" Margin="5" Height="35" Background="#444" Foreground="White"/>
                <Button Content="Wybierz" Click="Select_Click" Margin="5" Height="35" Background="#0078D4" Foreground="White"/>
            </UniformGrid>
        </Grid>
    </Border>
</Window>
