<Window x:Class="KOYA_APP.ActionPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Biblioteka Akcji" Height="750" Width="700"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" 
        WindowStartupLocation="CenterOwner"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <!-- Minimalist ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#66FFFFFF" CornerRadius="3" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" BorderThickness="1.5" BorderBrush="#44FFFFFF" ClipToBounds="True">
        <Border.Background>
            <SolidColorBrush Color="#111111"/>
        </Border.Background>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Extra Config -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="BIBLIOTEKA AKCJI" FontFamily="Segoe UI" FontWeight="ExtraBold" 
                           FontSize="20" Foreground="White" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" Color="White" Opacity="0.4" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Border Grid.Column="1" Background="#22FFFFFF" CornerRadius="8" BorderThickness="1" BorderBrush="#44FFFFFF" Width="240" Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}" FontSize="16" 
                                   Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" Foreground="White" 
                                 BorderThickness="0" VerticalContentAlignment="Center" FontSize="14" 
                                 CaretBrush="White" TextChanged="SearchBox_TextChanged" Padding="0,0,10,0"/>
                        <TextBlock IsHitTestVisible="False" Text="Wyszukaj akcję..." Grid.Column="1" VerticalAlignment="Center" 
                                   Foreground="#88FFFFFF" FontSize="14" Margin="2,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>

            <!-- 2. Content (Accordion Tree) -->
            <ListBox x:Name="ActionsListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="ActionsListBox_SelectionChanged">
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <Expander IsExpanded="True" Margin="0,0,0,15">
                                                <Expander.Header>
                                                    <Grid HorizontalAlignment="{Binding HorizontalAlignment, RelativeSource={RelativeSource AncestorType=ContentPresenter}}">
                                                        <TextBlock Text="{Binding Name}" FontWeight="ExtraBold" FontSize="13" Foreground="White" 
                                                                   Margin="0,8"/>
                                                    </Grid>
                                                </Expander.Header>
                                                <ItemsPresenter Margin="25,5,0,0"/>
                                            </Expander>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListBox.GroupStyle>
                
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="#0AFFFFFF"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="itemBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="15,12">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#22FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#44FFFFFF"/>
                                            <Setter TargetName="itemBorder" Property="BorderBrush" Value="White"/>
                                            <Setter TargetName="itemBorder" Property="BorderThickness" Value="1.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Colored Icon (Brighter colors) -->
                            <TextBlock x:Name="ActionIcon" Text="{Binding Icon}" FontFamily="{StaticResource IconFont}" FontSize="22" 
                                       VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="White"/>
                                <TextBlock x:Name="DescText" Text="{Binding Description}" 
                                           FontSize="11" Foreground="#CCFFFFFF" Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <Grid.ToolTip>
                                <ToolTip Background="#222222" BorderBrush="White" Foreground="White" Padding="10">
                                    <TextBlock Text="{Binding Description}" FontSize="13"/>
                                </ToolTip>
                            </Grid.ToolTip>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Category}" Value="Multimedia &amp; Audio">
                                <Setter TargetName="ActionIcon" Property="Foreground" Value="#00FF41"/> <!-- Matrix Green -->
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Category}" Value="System &amp; Okna">
                                <Setter TargetName="ActionIcon" Property="Foreground" Value="#FF3131"/> <!-- Bright Red -->
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Category}" Value="Internet &amp; Aplikacje">
                                <Setter TargetName="ActionIcon" Property="Foreground" Value="#1F51FF"/> <!-- Neon Blue -->
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Category}" Value="Automatyzacja &amp; Narzędzia">
                                <Setter TargetName="ActionIcon" Property="Foreground" Value="#FFD700"/> <!-- Gold -->
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Category}" Value="Zarządzanie PC">
                                <Setter TargetName="ActionIcon" Property="Foreground" Value="#FF5F1F"/> <!-- Neon Orange -->
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 3. Extra Config Area -->
            <Border Grid.Row="2" x:Name="ExtraSettingsPanel" Visibility="Collapsed" 
                    Background="#252525" CornerRadius="12" BorderThickness="2" BorderBrush="#55FFFFFF" 
                    Margin="0,20,0,0" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Color="Black" Opacity="0.8"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="ExtraSettingsTitle" Text="KONFIGURACJA PARAMETRÓW" 
                               FontSize="12" FontWeight="ExtraBold" Foreground="White" Margin="0,0,0,20"/>
                    <Grid>
                        <!-- Inputs styled for maximum visibility -->
                        <ComboBox x:Name="DevicesComboBox" Visibility="Collapsed" Height="45" Background="#333333" Foreground="White" BorderBrush="White" BorderThickness="1"/>
                        
                        <TextBox x:Name="ShortcutTextBox" Visibility="Collapsed" Height="45" Background="#333333" Foreground="White" 
                                 TextAlignment="Center" VerticalContentAlignment="Center" IsReadOnly="True" BorderThickness="2" BorderBrush="White"
                                 PreviewKeyDown="ShortcutTextBox_PreviewKeyDown" FontSize="16" FontWeight="Bold"/>
                        
                        <Grid x:Name="PasteTextPanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="PasteTextInput" Height="45" Background="#333333" Foreground="White" Padding="15,0" 
                                     VerticalContentAlignment="Center" BorderThickness="2,2,0,2" BorderBrush="White" FontSize="15" CaretBrush="White"/>
                            <Button x:Name="BrowseFileButton" Grid.Column="1" Click="BrowseFile_Click" Width="55" Height="45" 
                                    Background="#444444" BorderThickness="0,2,2,2" BorderBrush="White">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White"/>
                            </Button>
                        </Grid>

                        <Grid x:Name="ValueSliderPanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="ValueSlider" Minimum="0" Maximum="100" Value="50" TickFrequency="1" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" Margin="0,0,25,0" Height="30"/>
                            <Border Grid.Column="1" Background="#44FFFFFF" CornerRadius="8" Padding="10,6" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Value, ElementName=ValueSlider, StringFormat='{}{0}%'}" 
                                           Foreground="White" FontWeight="ExtraBold" FontSize="16" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <Grid x:Name="MacroPanel" Visibility="Collapsed" Height="160">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock x:Name="MacroStatusText" Text="GOTOWY" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <ScrollViewer Grid.Row="1" Background="#111111" Margin="0,12" CornerRadius="6" BorderThickness="1" BorderBrush="#33FFFFFF">
                                <ItemsControl x:Name="MacroSummaryList"/>
                            </ScrollViewer>
                            <Button x:Name="RecordMacroButton" Grid.Row="2" Click="RecordMacro_Click" Height="40" Content="NAGRAJ" Visibility="Collapsed" Background="#44FFFFFF" Foreground="White" FontWeight="Bold">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 4. Footer Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                <Button Click="Cancel_Click" Width="120" Height="45" Background="Transparent" BorderThickness="1.5" BorderBrush="#88FFFFFF" Margin="0,0,20,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1.5" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Anuluj" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </Button>

                <Button Click="Select_Click" Width="160" Height="45" Background="#44FFFFFF" BorderThickness="1.5" BorderBrush="White">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#66FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Zastosuj" Foreground="White" FontWeight="ExtraBold" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
