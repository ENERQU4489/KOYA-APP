<Window x:Class="KOYA_APP.ActionPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wybierz Akcje" Height="650" Width="450"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" 
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="0" BorderThickness="1.5">
        <Border.Background>
            <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,0" RadiusX="1" RadiusY="1">
                <GradientStop Color="#222222" Offset="0"/>
                <GradientStop Color="#050505" Offset="0.8"/>
            </RadialGradientBrush>
        </Border.Background>
        
        <Border.BorderBrush>
            <SolidColorBrush Color="#44FFFFFF"/>
        </Border.BorderBrush>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                <TextBlock Text="SYSTEM OVERRIDE" FontFamily="{StaticResource MainFont}" Foreground="White" 
                           FontSize="20" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="15" Color="White" ShadowDepth="0" Opacity="0.4"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="SELECT MODULE TO INSTALL" FontFamily="{StaticResource MainFont}" Foreground="#66FFFFFF" 
                           FontSize="9" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                <Separator Background="White" Margin="0,15,0,0" Height="1" Opacity="0.2"/>
            </StackPanel>

            <!-- Action List -->
            <ListBox x:Name="ActionsListBox" Grid.Row="1" Style="{StaticResource ActionListBoxStyle}" SelectionChanged="ActionsListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <Border Width="40" Height="40" CornerRadius="0" Background="#11FFFFFF" Margin="0,0,20,0" BorderBrush="#22FFFFFF" BorderThickness="1">
                                <TextBlock Text="{Binding Icon}" FontFamily="{StaticResource IconFont}" Foreground="White" 
                                           FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontFamily="{StaticResource MainFont}" Foreground="White" FontSize="13"/>
                                <TextBlock Text="{Binding Description}" Foreground="#55FFFFFF" FontSize="9" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Settings Panel -->
            <StackPanel x:Name="ExtraSettingsPanel" Grid.Row="2" Visibility="Collapsed" Margin="0,20,0,0">
                <TextBlock x:Name="ExtraSettingsTitle" Text="CONFIGURATION" FontFamily="{StaticResource MainFont}" 
                           Foreground="White" FontSize="9" Margin="0,0,0,10" Opacity="0.8"/>
                <Border BorderBrush="#33FFFFFF" BorderThickness="1" Background="#0AFFFFFF" CornerRadius="0">
                    <Grid>
                        <ComboBox x:Name="DevicesComboBox" Visibility="Collapsed" Height="45" Background="#111111" Foreground="White" BorderThickness="0" Padding="10,0"/>
                        <TextBox x:Name="ShortcutTextBox" Visibility="Collapsed" Height="45" Background="Transparent" Foreground="White" 
                                 TextAlignment="Center" VerticalContentAlignment="Center" IsReadOnly="True" BorderThickness="0"
                                 PreviewKeyDown="ShortcutTextBox_PreviewKeyDown" FontFamily="{StaticResource MainFont}" FontSize="12"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <UniformGrid Grid.Row="3" Columns="2" Margin="0,30,0,0">
                <Button Content="ABORT" Click="Cancel_Click" Style="{StaticResource GlassButtonStyle}" 
                        Height="50" Margin="5" FontSize="12" FontFamily="{StaticResource MainFont}"/>
                <Button Content="INSTALL" Click="Select_Click" Style="{StaticResource GlassButtonStyle}" 
                        Height="50" Margin="5" Background="#22FFFFFF" Foreground="White" BorderBrush="White" 
                        FontSize="12" FontFamily="{StaticResource MainFont}"/>
            </UniformGrid>
        </Grid>
    </Border>
</Window>
