<Window x:Class="KOYA_APP.ActionPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wybor Akcji" Height="500" Width="450"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" 
        WindowStartupLocation="CenterOwner">

    <Border Background="#1E1E1E" BorderBrush="#0078D4" BorderThickness="2" CornerRadius="15">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="KONFIGURACJA AKCJI" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <ListBox x:Name="ActionsListBox" Grid.Row="1" Background="#252525" Foreground="White" BorderThickness="0" SelectionChanged="ActionsListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#0078D4"/>       
                            <TextBlock Text="{Binding Description}" FontSize="10" Opacity="0.6" Foreground="White"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Panel dodatkowych ustawien -->
            <StackPanel x:Name="ExtraSettingsPanel" Grid.Row="2" Visibility="Collapsed" Margin="0,15,0,0">
                <TextBlock x:Name="ExtraSettingsTitle" Text="Ustawienia dodatkowe:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                
                <!-- Dla mikrofonu -->
                <ComboBox x:Name="DevicesComboBox" Background="#333" Foreground="Black" Height="30" Visibility="Collapsed">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FriendlyName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Dla skrótów klawiszowych -->
                <TextBox x:Name="ShortcutTextBox" Background="#333" Foreground="White" Height="35" 
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                         Text="Kliknij tutaj i wcisnij klawisze..." IsReadOnly="True" 
                         PreviewKeyDown="ShortcutTextBox_PreviewKeyDown" Visibility="Collapsed"/>
            </StackPanel>

            <UniformGrid Grid.Row="3" Columns="2" Margin="0,15,0,0">
                <Button Content="Anuluj" Click="Cancel_Click" Margin="5" Height="35" Background="#444" Foreground="White"/>
                <Button Content="Zatwierdz" Click="Select_Click" Margin="5" Height="35" Background="#0078D4" Foreground="White"/>
            </UniformGrid>
        </Grid>
    </Border>
</Window>
